{
    "name": "renfordt/prune",
    "description": "Find orphaned and unused PHP classes in your project",
    "type": "library",
    "require": {
        "php": "^8.4",
        "nikic/php-parser": "^5.0",
        "symfony/console": "^7.0",
        "symfony/finder": "^7.0",
        "nette/neon": "^3.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.0",
        "symfony/var-dumper": "^8.0",
        "phpunit/phpunit": "^12.5",
        "laravel/pint": "^1.19"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Renfordt\\Prune\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Renfordt\\Prune\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/prune"],
    "authors": [
        {
            "name": "renfordt",
            "email": "jannikrenfordt@gmx.de"
        }
    ],
    "scripts": {
        "analyze": "prune",
        "refacto": "rector",
        "lint": "pint",
        "test:refacto": "rector --dry-run",
        "test:lint": "pint --test",
        "test:types": "phpstan analyse --ansi",
        "test:unit": "phpunit",
        "test": [
            "@test:refacto",
            "@test:lint",
            "@test:types",
            "@test:unit"
        ]
    }
}
